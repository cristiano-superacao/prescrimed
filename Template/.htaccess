# Rewrite all requests to index.html for SPA
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite requests for static assets (ensure JS/CSS/images are served directly)
  RewriteRule ^assets/ - [L]

  # Don't rewrite existing files or directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Rewrite everything else to index.html (SPA fallback)
  RewriteRule ^ index.html [L]
</IfModule>

# Set long cache for assets
<IfModule mod_headers.c>
  # Ensure correct caching and CORS for static assets
  <FilesMatch "\.(js|mjs|css|woff2|woff|png|jpg|jpeg|svg|gif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>

  <FilesMatch "index.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Explicit MIME types in case server configuration is missing them
AddType application/javascript .js .mjs
AddType text/css .css
